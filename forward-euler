import numpy as np

def forward_euler(f, t0, y0, t_end, h):
    """
    Solves dy/dt = f(t, y) using the Forward Euler method.
    
    Parameters:
    f     : Function representing the derivative dy/dt. Must accept (t, y).
    t0    : Initial time.
    y0    : Initial value(s). Can be a scalar or a numpy array for systems.
    t_end : End time for the simulation.
    h     : Step size.
    """
    # Calculate the number of steps
    N = int(np.ceil((t_end - t0) / h))
    t = np.linspace(t0, t0 + N*h, N + 1)
    
    # Initialize the solution array 'y'
    # Check if y0 is a single number or a system of equations (array)
    if isinstance(y0, (int, float)):
        y = np.zeros(N + 1)
    else:
        y0 = np.array(y0)
        y = np.zeros((N + 1, len(y0)))
        
    y[0] = y0
    
    # Perform the Euler steps
    for i in range(N):
        y[i+1] = y[i] + h * f(t[i], y[i])
        
    return t, y



