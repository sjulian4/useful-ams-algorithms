import numpy as np

# The central difference method is generally preferred over forward or backward
#  differences because it has a higher-order truncation error, making it more accurate
#  for the same step size $h$.



def central_difference(f, x, h=1e-5):
    """
    Computes the numerical derivative of function f at point x 
    using the central difference formula.
    """
    return (f(x + h) - f(x - h)) / (2 * h)