import numpy as np

def gaussian_elimination(A, b):
    """
    Solves the system Ax = b using Gaussian elimination with partial pivoting.
    A must be an n x n invertible matrix.
    """
    n = len(b)
    # Create an augmented matrix to avoid modifying originals
    M = np.hstack([np.array(A, dtype=float), np.array(b, dtype=float).reshape(-1, 1)])
    
    # Forward Elimination
    for i in range(n):
        # Partial Pivoting: find the row with the largest absolute pivot
        max_row = np.argmax(np.abs(M[i:n, i])) + i
        if i != max_row:
            M[[i, max_row]] = M[[max_row, i]] # Swap rows
            
        # Eliminate entries below the pivot
        for j in range(i + 1, n):
            factor = M[j, i] / M[i, i]
            M[j, i:] -= factor * M[i, i:]
            
    # Back Substitution
    x = np.zeros(n)
    for i in range(n - 1, -1, -1):
        x[i] = (M[i, -1] - np.dot(M[i, i+1:n], x[i+1:n])) / M[i, i]
        
    return x