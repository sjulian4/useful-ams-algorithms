import numpy as np

def power_method(A, num_simulations=100, tol=1e-6):
    """
    Approximates the dominant eigenvalue and eigenvector of matrix A.
    
    Parameters:
    A : Square matrix
    num_simulations : Maximum number of iterations
    tol : Tolerance for convergence
    """
    n = A.shape[0]
    # Start with a random guess vector
    x = np.random.rand(n)
    x = x / np.linalg.norm(x)
    
    eigenvalue_old = 0
    
    for _ in range(num_simulations):
        # Multiply matrix by vector
        x_new = np.dot(A, x)
        
        # The Rayleigh quotient approximates the eigenvalue
        eigenvalue = np.dot(x, x_new)
        
        # Normalize the vector for the next iteration
        x = x_new / np.linalg.norm(x_new)
        
        # Check for convergence
        if np.abs(eigenvalue - eigenvalue_old) < tol:
            break
            
        eigenvalue_old = eigenvalue
        
    return eigenvalue, x